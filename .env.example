
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&connection_limit=1&statement_cache_size=0&prepared_statement_cache_size=0"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# OAuth Providers (Optional)
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# OAuth callback URLs (set these in your provider dashboard)
DISCORD_CALLBACK_URL="http://localhost:3000/api/auth/callback/discord"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/callback/google"
# Enable OAuth buttons in the UI
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"
NEXT_PUBLIC_DISCORD_AUTH_ENABLED="false"

# Stripe (for payments)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Platform Fees (percentages, must sum to <= 100 with Stripe Connect)
NEXT_PUBLIC_PLATFORM_FEE_PERCENT="10"
NEXT_PUBLIC_MODERATOR_FEE_PERCENT="3"
NEXT_PUBLIC_SERVER_FEE_PERCENT="2"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (for notifications)
EMAIL_SERVER=""
EMAIL_FROM=""

# File Upload
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Analytics
NEXT_PUBLIC_GA_ID=""

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="900000"
